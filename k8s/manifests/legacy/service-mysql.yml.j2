apiVersion: v1
kind: Service
metadata:
  name: mysql-svc
  namespace: {{ namespace }}
spec:
  type: ClusterIP
  ports:
    - port: 3306
      targetPort: 3306
      protocol: TCP
---
apiVersion: v1
kind: Endpoints
metadata:
  name: mysql-svc
  namespace: {{ namespace }}
subsets:
  - addresses:
      - ip: {{ ansible_default_ipv4.address }}
    ports:
      - port: 3306