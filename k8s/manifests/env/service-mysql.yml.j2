# MySQL Service + Endpoints — points each environment's namespace
# at the same host-level MySQL instance running on the node.
apiVersion: v1
kind: Service
metadata:
  name: mysql-svc
  namespace: {{ env.namespace }}
spec:
  type: ClusterIP
  ports:
    - port: 3306
      targetPort: 3306
      protocol: TCP
---
apiVersion: v1
kind: Endpoints
metadata:
  name: mysql-svc
  namespace: {{ env.namespace }}
subsets:
  - addresses:
      - ip: {{ ansible_default_ipv4.address }}
    ports:
      - port: 3306
